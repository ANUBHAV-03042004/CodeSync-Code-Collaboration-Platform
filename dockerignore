.idea/
*.iml
.classpath
.project
.settings/
.sts4-cache/
*.code-workspace
.vscode/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Local config overrides ────────────────────────────────────────────────────
*.env
.env*
application-local*.properties
application-local*.yml

# ── Kubernetes / OpenShift manifests (not needed inside the image) ────────────
deployment.yaml
service-route.yaml
configmap.yaml
*.yaml
*.yml

